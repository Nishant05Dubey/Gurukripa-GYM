rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users: Allow public read for Admin Analytics
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Maintenance Reports: Allow public read (protected by client-side password), auth write
    match /maintenance_reports/{reportId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
